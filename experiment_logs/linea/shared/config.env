# Linea autoresearch — gate configuration
#
# Source this from eval_*.sh scripts.
# All values are Linea-specific; tune only with experimental evidence.

# --- Wall-clock paired gate ---
# Keep threshold: benchstat geomean Δ% must be <= -KEEP_THRESHOLD_PCT to keep.
# TBD after noise floor characterization on Plonky3 server.
# ⚠️ QUESTION: leanMultisig found -1.5% too high for granular inline changes.
#    Set conservatively here; revisit after first 5 iters.
KEEP_THRESHOLD_PCT=1.5

# benchstat sample count (number of bench runs per side).
# ⚠️ QUESTION: noise floor on Plonky3 server unknown — characterize before first experiment.
COUNT=20

# Burn-in: one discarded run before recording.
BURN_IN=1

# --- iai-callgrind gate (if applicable) ---
# NOTE: Go profiling uses pprof, not iai-callgrind (Rust-specific).
# Equivalent for Go: benchstat + pprof diff. TBD.
# ⚠️ QUESTION: does the team have a Go instruction-count gate? If not, we own this.
IAI_EQUIV=pprof_diff  # placeholder — not yet implemented

# --- Revert-A/B ---
MARGINAL_MULT=2.0
MIN_REPRODUCE_FRACTION=0.5

# --- Regression guard ---
WALLCLOCK_REGRESSION_PCT=0.5
