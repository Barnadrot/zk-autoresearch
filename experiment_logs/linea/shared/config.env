# Linea autoresearch — gate configuration
#
# Source this from eval_*.sh scripts.
# All values are Linea-specific; tune only with experimental evidence.

# --- Wall-clock paired gate ---
# Keep threshold: benchstat geomean Δ% must be <= -KEEP_THRESHOLD_PCT to keep.
# FLAG 1: Set to 2×σ from noise_floor.sh (2026-04-16).
# Noise floor: σ ≈ 1.0% (geomean range -0.26% to +1.90% across 10 runs, GOGC=off).
# Largest single-benchmark swing: 3.96% (smallest case, vecs_15_len_1024).
KEEP_THRESHOLD_PCT=2.0

# benchstat sample count (number of bench runs per side).
COUNT=20

# Burn-in: one discarded run before recording.
BURN_IN=1

# --- Two-tier gating (FLAG 7) ---
# Tier 1 (every iter): BenchmarkLinearCombination in crypto/vortex/
# Tier 2 (keeps only): BenchmarkVortexHashPathsByRows in crypto/vortex/vortex_koalabear/
# Override these env vars to change benchmark targets.
# BENCH_PKG_OVERRIDE=
# BENCH_FILTER_OVERRIDE=

# --- Revert-A/B ---
MARGINAL_MULT=2.0
MIN_REPRODUCE_FRACTION=0.5

# --- Regression guard ---
WALLCLOCK_REGRESSION_PCT=0.5
