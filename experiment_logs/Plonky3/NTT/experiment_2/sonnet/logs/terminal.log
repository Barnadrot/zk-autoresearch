    type Output = Self;
    #[inline]
    fn sub(self, rhs: Self) -> Self {
        let lhs = self.to_vector();
        let rhs = rhs.to_vector();
        let res = mm512_mod_sub(lhs, rhs, PMP::PACKED_P);
        unsafe {
            Self::from_vector(res)
        }
    }
}
```

**New `Sub`** (same idea):
```rust
impl<PMP: PackedMontyParameters> Sub for PackedMontyField31AVX512<PMP> {
    type Output = Self;
    #[inline]
    fn sub(self, rhs: Self) -> Self {
        // We want this to compile to:
        //      vpsubd    t, lhs, rhs
        //      vpcmpltud underflow, lhs, rhs  (runs on port 5)
        //      vpaddd    res{underflow}, t, P
        // throughput: 1 cyc/vec
        // latency: 3 cyc
        unsafe {
            let lhs = self.to_vector();
            let rhs = rhs.to_vector();
            let t = x86_64::_mm512_sub_epi32(lhs, rhs);
            // underflow = (lhs < rhs): mask bits set where difference needs correction
            let underflow = x86_64::_mm512_cmplt_epu32_mask(lhs, rhs);
            let res = x86_64::_mm512_mask_add_epi32(t, underflow, t, PMP::PACKED_P);
            Self::from_vector(res)
        }
    }
}
```

