fn dit_layer_rev_last<F: Field>(submat: &mut RowMajorMatrixViewMut<'_, F>, twiddles_rev: impl Iterator<Item = F>, backwards: bool) {
    let width = submat.width();
    let twiddle_packed_iter = twiddles_rev.map(|t| F::Packing::from(t));
    let blocks = submat.values.chunks_mut(2 * width);
    if backwards {
        for (block, twiddle_packed) in blocks.rev().zip(twiddle_packed_iter.collect::<Vec<_>>().iter().rev()) {
            let (lo, hi) = block.split_at_mut(width);
            let (lo_packed, _) = F::Packing::pack_slice_with_suffix_mut(lo);
            let (hi_packed, _) = F::Packing::pack_slice_with_suffix_mut(hi);
            for (x1, x2) in lo_packed.iter_mut().zip(hi_packed.iter_mut()) {
