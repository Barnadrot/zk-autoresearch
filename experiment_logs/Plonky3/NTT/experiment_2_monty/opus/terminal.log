**Revised implementation:**
```rust
impl<PMP: PackedMontyParameters> Sub for PackedMontyField31AVX512<PMP> {
    #[inline]
    fn sub(self, rhs: Self) -> Self {
        // vptestmd extracts the sign bit from each 32-bit lane of t.
        // When both inputs are in [0, P) with P < 2^31:
        //   - If lhs >= rhs: t = lhs - rhs ∈ [0, P), bit 31 = 0 (no underflow)
        //   - If lhs < rhs:  t = lhs - rhs + 2^32 ∈ [2^32-P+1, 2^32), ≥ 2^32-P+1 > 2^31, bit 31 = 1
        // So bit 31 of t indicates underflow without re-reading lhs.
        unsafe {
            const SIGN_BIT: __m512i = unsafe { transmute([0x80000000u32; 16]) };
            let lhs = self.to_vector();
            let rhs = rhs.to_vector();
            let t = x86_64::_mm512_sub_epi32(lhs, rhs);
            // Check sign bit of t (AVX-512F, port 5)
            let underflow = x86_64::_mm512_test_epi32_mask(t, SIGN_BIT);
            let res = x86_64::_mm512_mask_add_epi32(t, underflow, t, PMP::PACKED_P);
            Self::from_vector(res)
        }
    }
}
```

