Optimization: **Create `dit_layer_oop_uniform_twiddle`** that broadcasts once and processes all 512 row-pairs in a single loop:

```rust
fn dit_layer_oop_uniform_twiddle<F: Field>(
    src: &RowMajorMatrixView<'_, F>,
    dst: &mut RowMajorMatrixViewMut<'_, MaybeUninit<F>>,
    twiddle: F,
) {
    let width = src.width();
    let twiddle_packed = F::Packing::from(twiddle);
    // Process all row-pairs
    for (src_pair, dst_pair) in src.values.chunks(2 * width).zip(dst.values.chunks_mut(2 * width)) {
        let (src_lo, src_hi) = src_pair.split_at(width);
        let (dst_lo, dst_hi) = dst_pair.split_at_mut(width);
        // packed butterfly with pre-broadcast twiddle
        let (src_lo_p, src_lo_s) = F::Packing::pack_slice_with_suffix(src_lo);
        let (src_hi_p, src_hi_s) = F::Packing::pack_slice_with_suffix(src_hi);
        let (dst_lo_p, dst_lo_s) = F::Packing::pack_maybe_uninit_slice_with_suffix_mut(dst_lo);
        let (dst_hi_p, dst_hi_s) = F::Packing::pack_maybe_uninit_slice_with_suffix_mut(dst_hi);
        for (sl, sh, dl, dh) in izip!(src_lo_p, src_hi_p, dst_lo_p, dst_hi_p) {
            let x2t = *sh * twiddle_packed;
            dl.write(*sl + x2t);
            dh.write(*sl - x2t);
        }
        for (sl, sh, dl, dh) in izip!(src_lo_s, src_hi_s, dst_lo_s, dst_hi_s) {
            let x2t = *sh * twiddle;
            dl.write(*sl + x2t);
            dh.write(*sl - x2t);
        }
    }
}
```

