**New `Add`** (uses mask comparison on port 5 instead of `vpminud` on port 0):
```rust
impl<PMP: PackedMontyParameters> Add for PackedMontyField31AVX512<PMP> {
    type Output = Self;
    #[inline]
    fn add(self, rhs: Self) -> Self {
        // We want this to compile to:
        //      vpaddd    t, lhs, rhs
        //      vpcmpgeud overflow, t, P   (runs on port 5, not port 0 like vpminud)
        //      vpsubd    res{overflow}, t, P
        // This avoids `vpminud` which runs on port 0 (already under heavy pressure from multiplications).
        // throughput: 1 cyc/vec
        // latency: 3 cyc
        unsafe {
            let lhs = self.to_vector();
            let rhs = rhs.to_vector();
            let t = x86_64::_mm512_add_epi32(lhs, rhs);
            // overflow = (t >= P): mask bits set where sum needs reduction
            let overflow = x86_64::_mm512_cmpge_epu32_mask(t, PMP::PACKED_P);
            let res = x86_64::_mm512_mask_sub_epi32(t, overflow, t, PMP::PACKED_P);
            Self::from_vector(res)
        }
    }
}
```

**Original `Sub`:**
```rust
