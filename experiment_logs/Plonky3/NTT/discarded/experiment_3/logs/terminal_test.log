```rust
fn dit_layer_rev_first2_general<F: Field>(
    submat: &mut RowMajorMatrixViewMut<'_, F>,
    t1: F,         // twiddle for layer `mid`
    t2_a: F,       // twiddle for layer `mid+1`, block 0 (top half)
    t2_b: F,       // twiddle for layer `mid+1`, block 1 (bottom half)
) {
    let width = submat.width();
    let total_rows = submat.height();
    let qh = total_rows / 4;  // quarter height
    
