Actually, for the fused first-two-layers approach in `second_half_general`, the structure is:

```rust
fn dit_layer_rev_first2_general<F: Field>(
    submat: &mut RowMajorMatrixViewMut<'_, F>,
    twiddle9: F,  // single twiddle for layer_rev=9
    twiddles8: &[F],  // 2 twiddles for layer_rev=8
) {
    let width = submat.width();
    let height = submat.height(); // 1024 rows
    let quarter = height / 4;    // 256
    
    // The 4 row groups are: rows 0..256, rows 256..512, rows 512..768, rows 768..1024
    // Split into 4 slices
    let (group0, rest) = submat.values.split_at_mut(quarter * width);
    let (group1, rest) = rest.split_at_mut(quarter * width);
    let (group2, group3) = rest.split_at_mut(quarter * width);
    
    let t9_packed = F::Packing::from(twiddle9);
    let t8a_packed = F::Packing::from(twiddles8[0]);
    let t8b_packed = F::Packing::from(twiddles8[1]);
    
    let (g0_packed, g0_suffix) = F::Packing::pack_slice_with_suffix_mut(group0);
    let (g1_packed, g1_suffix) = F::Packing::pack_slice_with_suffix_mut(group1);
    let (g2_packed, g2_suffix) = F::Packing::pack_slice_with_suffix_mut(group2);
    let (g3_packed, g3_suffix) = F::Packing::pack_slice_with_suffix_mut(group3);
    
    for (p0, p1, p2, p3) in izip!(g0_packed.iter_mut(), g1_packed.iter_mut(), g2_packed.iter_mut(), g3_packed.iter_mut()) {
        // Layer_rev=9: butterfly (p0, p2) and (p1, p3) with t9
        let r2t = *p2 * t9_packed;
        let r3t = *p3 * t9_packed;
        let new_r0 = *p0 + r2t;
        let new_r1 = *p1 + r3t;
        let new_r2 = *p0 - r2t;
        let new_r3 = *p1 - r3t;
        
        // Layer_rev=8: butterfly (new_r0, new_r1) with t8a, (new_r2, new_r3) with t8b
        let r1t = new_r1 * t8a_packed;
        let r3t = new_r3 * t8b_packed;
        *p0 = new_r0 + r1t;
        *p1 = new_r0 - r1t;
        *p2 = new_r2 + r3t;
        *p3 = new_r2 - r3t;
    }
    // ... suffix handling
}
```

