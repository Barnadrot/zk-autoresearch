# leanMultisig autoresearch — gate configuration
#
# Source this file from eval_*.sh scripts or set these vars in the loop
# orchestrator's environment. All values are leanMultisig-specific; tune
# only with experimental evidence.

# --- Wall-clock paired gate (eval_paired.sh) ------------------------
# Keep threshold: median Δ% must be <= -KEEP_THRESHOLD_PCT to be kept.
# Set from the empirical paired σ in report/threshold_calibration.md.
# Default is a conservative initial value; the calibration report supersedes.
KEEP_THRESHOLD_PCT=1.5

# Criterion sample parameters (same as current eval_e2e.sh).
SAMPLE_SIZE=10
MEASUREMENT_TIME=60

# Burn-in length (seconds). One discarded invocation, criterion --profile-time.
BURN_IN_PROFILE_TIME=30

# Marginal threshold: keeps where |Δ| < MARGINAL_MULT × KEEP_THRESHOLD_PCT
# trigger the revert-A/B sanity check.
MARGINAL_MULT=2.0

# --- iai-callgrind gate (eval_iai.sh) -------------------------------
# Stage 1 PASS: some tracked symbol dropped ≥ IAI_MIN_DROP_PCT on Ir AND
# no tracked symbol regressed by more than IAI_MAX_REGR_PCT on Ir.
IAI_MIN_DROP_PCT=0.10
IAI_MAX_REGR_PCT=0.05

# --- Revert-A/B (eval_revert_ab.sh) ---------------------------------
# Revert must reproduce at least this fraction of the claimed improvement
# (positive delta when the keep is reverted on top of HEAD).
MIN_REPRODUCE_FRACTION=0.5
